# ==============================================================================
# 1. Quantitative Data Providers (Prices, Candles, & WebSocket Ticks)
# ==============================================================================

# Swiss-army knife for real-time multi-asset crypto ticks and core fundamental market events
FINNHUB=
# Ultra-low latency provider specializing in real-time forex, crypto, and global tick streaming
ALLTICK=


# ==============================================================================
# 2. Qualitative Data Providers (Alternative Text, News, & Sentiment Logs)
# ==============================================================================

# Broad global news aggregator ideal for high-volume text querying on macro keywords
NEWSAPI=
# Specialized financial news API that automatically maps unstructured text to stock tickers
MARKETAUX=


# ==============================================================================
# 3. Enterprise Infrastructure & Analytics Storage Engine
# ==============================================================================

# Connection string for your fully managed Amazon MSK or Confluent Cloud Kafka cluster
KAFKA_BOOTSTRAP_SERVERS=
# Administrative username for your managed Snowflake cloud data warehouse
SNOWFLAKE_USER=
# Secure access token or password for your remote Snowflake analytical environment
SNOWFLAKE_PASSWORD=
# Unique organization account identifier needed to point your dbt framework to Snowflake
SNOWFLAKE_ACCOUNT=